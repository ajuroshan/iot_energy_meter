# AWS Configuration
aws_region = "ap-south-1"

# Project name (used for resource naming)
project_name = "iot-energy-meter"

# EC2 Instance Configuration
instance_type = "t3.small"

# SSH key pair name (must exist in AWS)
key_pair_name = "your-key-pair-name"

# Your IP address for SSH access (use https://whatismyip.com to find it)
# Format: x.x.x.x/32
admin_ip = "YOUR_IP_ADDRESS/32"

# Database password (use a strong password)
postgres_password = "your-secure-password-here"

# Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
django_secret_key = "your-django-secret-key-here"

# Optional: Domain name (leave empty to use IP address)
domain_name = ""
